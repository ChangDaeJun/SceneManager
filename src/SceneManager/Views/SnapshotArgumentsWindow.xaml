<Window x:Class="SceneManager.Views.SnapshotArgumentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:SceneManager.Controls"
        Title="스냅샷 — 실행 인자" Height="680" Width="820"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <StackPanel Grid.Row="0" Margin="2,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="실행 인자 확인" FontWeight="Bold" FontSize="14"/>
                <TextBlock Text="{Binding Position}" Margin="10,0,0,0" FontSize="14"
                           Foreground="#6B7280" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock TextWrapping="Wrap" Foreground="#374151" Margin="0,4,0,0"
                       Text="파일이나 URL이 열린 상태로 복원하려면 각 프로그램의 실행 인자를 넣으세요. 지도에서 빨간 창이 현재 대상입니다(지도를 클릭해 대상을 바꿀 수 있습니다). 인자를 모르면 '인자 찾기 도우미'로 AI에게 물어볼 프롬프트를 복사하세요."/>
        </StackPanel>

        <!-- 배치도(현재 대상 강조) -->
        <Border Grid.Row="1" BorderBrush="#E5E7EB" BorderThickness="1" Background="White">
            <ctl:LayoutPreview x:Name="Map"
                               Monitors="{Binding Monitors}"
                               Scene="{Binding Scene}"
                               SelectedProgram="{Binding CurrentProgram, Mode=TwoWay}"/>
        </Border>

        <!-- 현재 프로그램 상세 -->
        <Border Grid.Row="2" Margin="0,12,0,0" Padding="12" Background="#F9FAFB"
                BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="이름" Foreground="#6B7280" Margin="0,0,12,4"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentProgram.Name}" FontWeight="SemiBold" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="실행 경로" Foreground="#6B7280" Margin="0,0,12,4"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentProgram.ExecPath}"
                           TextWrapping="Wrap" Foreground="#374151" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="창 제목" Foreground="#6B7280" Margin="0,0,12,4"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentProgram.WindowTitle}"
                           TextWrapping="Wrap" Foreground="#374151" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="실행 인자" Foreground="#6B7280"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Grid Grid.Row="3" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="ArgsBox" Height="28" VerticalContentAlignment="Center"
                             FontFamily="Consolas"
                             Text="{Binding CurrentProgram.Arguments, UpdateSourceTrigger=LostFocus, TargetNullValue=''}"/>
                    <Button Grid.Column="1" Content="🤖 인자 찾기 도우미" Margin="8,0,0,0" Padding="10,4"
                            Click="OnShowHelper"/>
                </Grid>

                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Hint}" TextWrapping="Wrap"
                           Foreground="#2563EB" FontSize="12" Margin="0,6,0,0"/>
            </Grid>
        </Border>

        <!-- 하단바 -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Button Content="◀ 이전" Command="{Binding PrevCommand}" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="다음 ▶" Command="{Binding NextCommand}" Padding="12,4"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="확인(저장)" Width="110" Margin="0,0,8,0" IsDefault="True" Click="OnOk"/>
                <Button Content="취소" Width="90" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
