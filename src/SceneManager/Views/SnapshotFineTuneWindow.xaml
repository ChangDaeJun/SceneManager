<Window x:Class="SceneManager.Views.SnapshotFineTuneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:SceneManager.Controls"
        xmlns:vm="clr-namespace:SceneManager.ViewModels"
        Title="스냅샷 미세조정" Height="660" Width="900"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="OnPreviewKeyDown">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="2,0,0,8" TextWrapping="Wrap" Foreground="#374151"
                   Text="창을 클릭/선택 후 — 방향키: 1px 이동 · Ctrl+방향키: 크기 조절 · Delete: 삭제 · Ctrl+Z: 실행취소.  x/y/w/h를 직접 입력해도 실제 창이 즉시 반영됩니다."/>

        <!-- 배치도 -->
        <Border Grid.Row="1" BorderBrush="#E5E7EB" BorderThickness="1" Background="White">
            <ctl:LayoutPreview x:Name="Map"
                               Monitors="{Binding Monitors}"
                               Scene="{Binding Scene}"
                               SelectedProgram="{Binding SelectedEntry, Mode=TwoWay}"/>
        </Border>

        <TextBlock Grid.Row="2" Text="프로그램" FontWeight="Bold" Margin="2,10,0,6"/>

        <!-- 프로그램 표(좌표 편집 가능) -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Programs}"
                  SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="130" IsReadOnly="True"/>
                <DataGridTextColumn Header="타입" Binding="{Binding Type}" Width="60" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="상태" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding Source={x:Static vm:ProgramEditViewModel.StateOptions}}"
                                      SelectedItem="{Binding State, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      BorderThickness="0" Background="Transparent" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="X" Binding="{Binding X}" Width="72"/>
                <DataGridTextColumn Header="Y" Binding="{Binding Y}" Width="72"/>
                <DataGridTextColumn Header="W" Binding="{Binding Width}" Width="72"/>
                <DataGridTextColumn Header="H" Binding="{Binding Height}" Width="72"/>
                <DataGridTextColumn Header="실행 경로" Binding="{Binding ExecPath}" Width="*" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 하단바 -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Button Content="🧹 틈 메우기" Command="{Binding TidyLayoutCommand}" Padding="10,4" Margin="0,0,8,0"/>
                <Button Content="🗑 선택 삭제" Command="{Binding DeleteSelectedCommand}" Padding="10,4" Margin="0,0,8,0"/>
                <Button Content="↩ 실행취소" Command="{Binding UndoCommand}" Padding="10,4" Margin="0,0,14,0"/>
                <CheckBox Content="모서리 각지게" IsChecked="{Binding SquareCorners}" VerticalAlignment="Center"
                          ToolTip="스냅처럼 창을 딱 붙일 때 Windows 11의 둥근 모서리를 없앱니다."/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="확인" Width="90" Margin="0,0,8,0" IsDefault="True" Click="OnOk"/>
                <Button Content="취소" Width="90" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
