<Window x:Class="SceneManager.Views.SnapshotPriorityWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="스냅샷 — 실행 순서 · 의존성" Height="560" Width="760"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="2,0,0,10" TextWrapping="Wrap" Foreground="#374151"
                   Text="프로그램 실행 순서와 의존성을 정합니다. 행을 선택하고 ▲/▼로 순서를 바꾸세요. '의존' 대상을 지정하면 그 프로그램이 먼저 실행된 뒤에 이 프로그램이 실행됩니다. 지연(ms)은 실행 후 다음까지 기다릴 시간입니다."/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0" x:Name="OrderGrid"
                      ItemsSource="{Binding Programs}"
                      SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      CanUserAddRows="False" CanUserReorderColumns="False" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Position}" Width="40" IsReadOnly="True"/>
                    <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="150" IsReadOnly="True"/>
                    <DataGridTextColumn Header="타입" Binding="{Binding Type}" Width="60" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="의존(먼저 실행)" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DependencyOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedItem="{Binding SelectedDependency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          BorderThickness="0" Background="Transparent" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="지연(ms)" Binding="{Binding DelayAfterMs}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="10,0,0,0">
                <Button Content="▲ 위로" Command="{Binding MoveUpCommand}" Width="80" Padding="0,4" Margin="0,0,0,6"/>
                <Button Content="▼ 아래로" Command="{Binding MoveDownCommand}" Width="80" Padding="0,4"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="확인(저장)" Width="110" Margin="0,0,8,0" IsDefault="True" Click="OnOk"/>
            <Button Content="취소" Width="90" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
