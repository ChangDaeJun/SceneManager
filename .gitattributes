# 기본: 텍스트 파일은 자동 감지 후 저장소에 LF로 정규화, 체크아웃 시 OS 기본
* text=auto

# 소스/설정 파일 명시 (C# diff 힌트 포함)
*.cs        text diff=csharp
*.csproj    text
*.sln       text
*.slnx      text
*.props     text
*.targets   text
*.json      text
*.xml       text
*.md        text
*.yml       text
*.yaml      text
*.gitignore text
*.gitattributes text

# 바이너리 (정규화/diff 제외)
*.png  binary
*.jpg  binary
*.ico  binary
*.dll  binary
*.exe  binary
*.pdb  binary
